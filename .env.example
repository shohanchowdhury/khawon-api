# Railway deployment (internal hostname — only works inside Railway)
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway

# Local dev: Railway public Postgres URL from dashboard > Postgres > Connect
# DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway

# Or use local SQLite when Railway public URL is unavailable
# USE_SQLITE=1

# JWT secret for user auth (change in production)
JWT_SECRET=change-me-in-production
