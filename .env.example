# Railway deployment (internal hostname — only works inside Railway)
DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway

# Local dev: Railway public Postgres URL from dashboard > Postgres > Connect
# DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway

# Or use local SQLite when Railway public URL is unavailable
# USE_SQLITE=1

# JWT secret for user auth (change in production)
JWT_SECRET=change-me-in-production

# Cloudinary image uploads (https://cloudinary.com)
# Option A: three separate vars from Settings > API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Option B: single URL from API Keys page (replace placeholders with real key/secret)
# CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME

# Google Places (https://console.cloud.google.com) — enable "Places API (New)"
# Billing must be enabled on the project. Pay-as-you-go, no subscription — each
# API "SKU" (endpoint + field combo) gets its own free monthly call allowance that
# resets monthly and doesn't roll over (this got restructured March 2025; it used
# to be a flat $200/mo credit across everything, that's gone). Same key for lookup + photos.
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Hugging Face — AI food photo generation
# 1. https://huggingface.co/settings/tokens → Create fine-grained token
# 2. Enable permission: "Make calls to Inference Providers" (Read-only is NOT enough)
# 3. Accept model license: https://huggingface.co/black-forest-labs/FLUX.1-schnell
HF_TOKEN=hf_your_token_here
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HF_INFERENCE_PROVIDER=hf-inference
